# BountyFrame — deployment environment (Bradbury testnet only)
# Copy to .env and fill in. NEVER commit .env or share the private key.

# Private key of the funded deployer account (Bradbury testnet).
# Fund it via the faucet: https://testnet-faucet.genlayer.foundation
# Format: 0x-prefixed 64-hex-char string.
ACCOUNT_PRIVATE_KEY=

# GenLayer RPC (Bradbury). Default is correct; override only if needed.
GENLAYER_RPC_URL=https://rpc-bradbury.genlayer.com
